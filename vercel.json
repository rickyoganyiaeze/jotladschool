{
  "version": 2,
  "name": "joladschool",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(css|js|images|uploads)/(.*\\.(.*))",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/admin",
      "dest": "/public/admin.html",
      "headers": { "Content-Type": "text/html" }
    },
    {
      "src": "/result-checker",
      "dest": "/public/result-checker.html",
      "headers": { "Content-Type": "text/html" }
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}